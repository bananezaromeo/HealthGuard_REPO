# Backend API Configuration - EXAMPLE
# Copy this file to .env and update the values for your network

# Format: PROTOCOL (http or https)
API_PROTOCOL=http

# Format: IP Address or hostname of your backend server
# Examples:
#   - localhost (for local development)
#   - 127.0.0.1 (same machine)
#   - 10.0.2.2 (Android emulator - special alias to host machine)
#   - 192.168.x.x (other devices on same network)
#   - 10.0.x.x (corporate network)
API_HOST=localhost

# Backend server port number
API_PORT=5000

# Full API base URL (constructed from above values)
API_BASE_URL=$API_PROTOCOL://$API_HOST:$API_PORT/api
